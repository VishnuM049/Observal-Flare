# Flare environment config
FLARE_ENV=local

# Database (Flare's own PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flare

# Redis
REDIS_URL=redis://localhost:6379

# Auth
SECRET_KEY=change-me-in-production
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ORG=BlazeUp-AI

# GitHub API (ref resolution, PR comments, org membership)
GITHUB_TOKEN=
GITHUB_REPO_OWNER=BlazeUp-AI
GITHUB_REPO_NAME=Observal
GITHUB_WEBHOOK_SECRET=

# AWS (only needed for AWS sites in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Terraform state (AWS)
TERRAFORM_STATE_BUCKET=flare-terraform-state
TERRAFORM_LOCK_TABLE=flare-terraform-locks

# GCP (only needed for GCP sites in production)
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GCP_TERRAFORM_STATE_BUCKET=
# Path to service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=

# Route53 (used for DNS on both AWS and GCP sites)
ROUTE53_ZONE_ID=
SITE_BASE_DOMAIN=observal.io

# Flare public URL
FLARE_BASE_URL=https://flare.observal.io

# WebSocket (frontend connects directly to API for real-time updates)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Mock overrides (optional, defaults follow FLARE_ENV)
# Set to false to use real implementations while keeping FLARE_ENV=local
# MOCK_GITHUB=false
# MOCK_TERRAFORM=false
# MOCK_SSM=false
# MOCK_COMPUTE=false
