# Flare environment config
FLARE_ENV=local

# Database (Flare's own PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flare

# Redis
REDIS_URL=redis://localhost:6379

# Auth
SECRET_KEY=change-me-in-production
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ORG=BlazeUp-AI

# GitHub API (ref resolution, PR comments, org membership)
GITHUB_TOKEN=
GITHUB_REPO_OWNER=BlazeUp-AI
GITHUB_REPO_NAME=Observal

# AWS (only needed in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Terraform state
TERRAFORM_STATE_BUCKET=flare-terraform-state
TERRAFORM_LOCK_TABLE=flare-terraform-locks

# Route53
ROUTE53_ZONE_ID=
SITE_BASE_DOMAIN=observal.io

# Email
SES_FROM_ADDRESS=noreply@observal.io

# Flare public URL
FLARE_BASE_URL=https://flare.observal.io
